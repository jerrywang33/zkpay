{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["packages/**/*.ts", "apps/**/*.ts", "examples/**/*.ts", "tests/**/*.ts"]
}
