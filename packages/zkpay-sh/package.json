{
  "name": "zkpay-sh",
  "version": "0.2.0-alpha.16",
  "description": "Sui stablecoin checkout SDK and CLI for zkpay.sh.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://zkpay.sh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jerrywang33/zkpay.git",
    "directory": "packages/zkpay-sh"
  },
  "bugs": {
    "url": "https://github.com/jerrywang33/zkpay/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    }
  },
  "bin": {
    "zkpay": "dist/cli/index.js",
    "zkpay-sh": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/build-public-package.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@mysten/sui": "^2.17.0",
    "hono": "^4.12.23",
    "zod": "^3.25.0"
  }
}
